# ==========================================
# KIAL AVSEC Backend - Environment Configuration
# ==========================================

# Server Configuration
PORT=5000
NODE_ENV="development"  # Change to "production" for production

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/kial_avsec?schema=public"

# JWT Configuration - CRITICAL FOR SECURITY
# Generate strong secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Email Configuration (SMTP) - Optional, uses mock if not set
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@kial.avsec.com"

# Cron Jobs Configuration
ENABLE_CRON="true"

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH="./uploads"

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ==========================================
# PRODUCTION SECURITY CHECKLIST
# ==========================================
# [ ] Set NODE_ENV="production"
# [ ] Generate strong JWT_SECRET (openssl rand -base64 32)
# [ ] Configure production DATABASE_URL with strong password
# [ ] Set up SMTP credentials for email notifications
# [ ] Enable HTTPS/SSL only
# [ ] Review and adjust rate limit settings
# [ ] Set up automated database backups
# [ ] Configure centralized logging (Winston/Loggly)
# [ ] Set up error tracking (Sentry)
# [ ] Enable monitoring and alerts
# [ ] Review file upload security
# [ ] Implement database connection pooling limits
# [ ] Set up firewall rules
# [ ] Enable audit logging
# ==========================================
